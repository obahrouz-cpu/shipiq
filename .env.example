# ── Supabase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── Oxylabs Web Scraper (required for auto weight calculation) ────────────────
# Sign up at oxylabs.io
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# ── RapidAPI (Amazon product image fetching) ──────────────────────────────────
# Sign up at rapidapi.com → subscribe to "Real-Time Amazon Data" API
RAPIDAPI_KEY=

# ── WhatsApp notifications (optional — choose one provider) ───────────────────
WHATSAPP_PROVIDER=ultramsg  # or 'twilio'
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+1234567890

# ── Accounting integration (optional — configure via Admin Settings UI) ───────
WAVE_ACCESS_TOKEN=
WAVE_BUSINESS_ID=
ZOHO_ACCESS_TOKEN=
ZOHO_ORG_ID=

# ── Payment gateways (not yet implemented) ────────────────────────────────────
FIB_API_KEY=
FIB_MERCHANT_ID=
FIB_SECRET=
QICARD_API_KEY=
QICARD_MERCHANT_ID=
QICARD_SECRET=

# ── Push notifications (Firebase Cloud Messaging) ─────────────────────────────
# Server-only — NEVER expose to the browser. The ENTIRE service-account JSON
# key, as a single line. Generate it in the Firebase Console:
# Project settings → Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com"}
# Shared secret guarding POST /api/push/test (the manual "send one push" route).
PUSH_API_SECRET=replace-with-a-long-random-string

# ── Order-expiry cron (Vercel Cron → GET /api/cron/order-expiry) ──────────────
# Vercel automatically sends `Authorization: Bearer <CRON_SECRET>` on scheduled
# invocations when this is set. The route rejects any request without it, so
# randoms can't trigger the auto-void / push run. Use a long random string.
CRON_SECRET=replace-with-a-long-random-string
